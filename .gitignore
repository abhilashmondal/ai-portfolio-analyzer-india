# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
tmp/
out-tsc/
build/
*.tsbuildinfo
.expo/
.expo-shared/

# ── Dependencies ───────────────────────────────────────────────────────────────
node_modules/

# ── Environment & secrets (NEVER commit these) ────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.cert

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
testem.log

# ── Test / coverage ───────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Cache & temp ──────────────────────────────────────────────────────────────
.cache/
.turbo/
.parcel-cache/
*.tgz

# ── Replit-specific (local tooling, not part of the codebase) ─────────────────
.local/
.agents/
attached_assets/
.replitignore

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V500
.Trashes
Thumbs.db
desktop.ini

# ── IDEs ──────────────────────────────────────────────────────────────────────
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.sublime-workspace
*.sublime-project
.project
.classpath
.settings/
*.launch
.c9/

# ── TypeScript declaration outputs (generated from source) ────────────────────
*.d.ts.map

# ── Misc ──────────────────────────────────────────────────────────────────────
/.sass-cache
/connect.lock
/libpeerconnection.log
/typings
